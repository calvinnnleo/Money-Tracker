# ID Google Spreadsheet (sama dengan yang dipakai bot)
GOOGLE_SHEET_ID=

# Isi file service-account.json, di-encode base64 (satu baris)
# Cara: base64 -w 0 service-account.json   (Linux/Mac)
#       certutil -encode service-account.json tmp.txt (Windows, lalu buang header/footernya)
GOOGLE_SERVICE_ACCOUNT_KEY_BASE64=
