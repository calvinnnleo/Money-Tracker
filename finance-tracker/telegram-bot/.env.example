# Token dari @BotFather di Telegram
TELEGRAM_BOT_TOKEN=

# ID Telegram kamu (biar bot cuma respons ke kamu, bukan orang lain)
# Cara cek: chat @userinfobot di Telegram
TELEGRAM_OWNER_ID=

# URL project Supabase kamu (ambil dari Settings -> API)
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Service Role Key Supabase (untuk bypass RLS & menulis dari server bot)
# Ambil dari Settings -> API -> service_role (jangan di-share!)
SUPABASE_SERVICE_ROLE_KEY=

