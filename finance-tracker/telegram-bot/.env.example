# Token dari @BotFather di Telegram
TELEGRAM_BOT_TOKEN=

# ID Telegram kamu (biar bot cuma respons ke kamu, bukan orang lain)
# Cara cek: chat @userinfobot di Telegram
TELEGRAM_OWNER_ID=

# ID Google Spreadsheet (ambil dari URL sheet-nya)
# https://docs.google.com/spreadsheets/d/INI_ID_NYA/edit
GOOGLE_SHEET_ID=

# Path ke file JSON service account (lihat README untuk cara membuat)
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./service-account.json
